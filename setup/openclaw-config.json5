// OpenClaw Configuration (v2026.2.x format)
// Deploy to: ~/.openclaw/openclaw.json on VPS
// API key goes in ~/.openclaw/.env (not here!)
{
  // Gateway - loopback ONLY for security
  gateway: {
    bind: "loopback",
    port: 18789,
    mode: "local"
  },

  // Agent defaults (migrated from legacy agent.* format)
  agents: {
    defaults: {
      // LLM model
      model: {
        primary: "anthropic/claude-opus-4-6"
      },

      // Thinking level for reasoning
      thinkingDefault: "high",

      // Heartbeat - proactive check-ins
      heartbeat: {
        every: "30m",
        target: "last",
        activeHours: {
          start: "08:00",
          end: "22:00",
          timezone: "America/Los_Angeles"
        }
      },

      // Sandbox for non-main sessions
      sandbox: {
        mode: "non-main",
        scope: "agent",
        docker: {
          image: "openclaw-sandbox:bookworm-slim",
          network: "none",
          readOnlyRoot: true
        }
      }
    }
  },

  // Messaging channels
  channels: {
    whatsapp: {
      // "pairing" = must approve each new contact
      dmPolicy: "pairing",
      // Your phone number in E.164 format
      allowFrom: ["+1YOURNUMBER"],
      // Disable group chats initially
      groupPolicy: "disabled",
      sendReadReceipts: true,
      textChunkLimit: 4000
    },

    telegram: {
      // Bot token from @BotFather — set TELEGRAM_BOT_TOKEN in ~/.openclaw/.env
      botToken: "${TELEGRAM_BOT_TOKEN}",
      // Only accept messages from your Telegram user ID (find via @userinfobot)
      dmPolicy: "allowlist",
      allowFrom: [8092664267],
      groupPolicy: "disabled"
    }
  }
}

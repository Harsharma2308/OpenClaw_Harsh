// OpenClaw Configuration (v2026.3.x format)
// Deploy to: ~/.openclaw/openclaw.json on VPS
// API key goes in ~/.openclaw/.env.secrets (not here!)
{
  // Gateway - loopback ONLY for security
  gateway: {
    bind: "loopback",
    port: 18789,
    mode: "local"
  },

  // Model providers
  // claude-max: routes through claude-max-api-proxy (Claude subscription, no per-token cost)
  // haimaker: fallback only (free tier, $10/day cap — only used if proxy is down)
  models: {
    mode: "merge",
    providers: {
      "claude-max": {
        baseUrl: "http://localhost:3456/v1",
        apiKey: "not-needed",
        api: "openai-completions",
        models: [
          {
            id: "claude-sonnet-4-5",
            name: "Claude Sonnet 4.5 (via subscription)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 200000,
            maxTokens: 8192
          },
          {
            id: "claude-opus-4-6",
            name: "Claude Opus 4.6 (via subscription)",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 200000,
            maxTokens: 8192
          }
        ]
      }
    }
  },

  // Agent defaults
  agents: {
    defaults: {
      // Primary: Claude subscription via local proxy (free, no daily limit)
      // Fallback: direct Anthropic API (costs money, use if proxy is down)
      model: {
        primary: "claude-max/claude-sonnet-4-5",
        fallbacks: []  // no fallback to Anthropic direct — avoids unexpected API charges
      },

      // Model aliases (use /model opus to escalate in chat)
      models: {
        "claude-max/claude-sonnet-4-5": { alias: "sonnet" },
        "claude-max/claude-opus-4-6": { alias: "opus" },
        "anthropic/claude-sonnet-4-5": { alias: "sonnet-api" },
        "anthropic/claude-opus-4-6": {
          alias: "opus-api",
          params: { cacheRetention: "short" }
        }
      },

      thinkingDefault: "high",

      // Heartbeat - proactive check-ins via subscription (zero extra cost)
      heartbeat: {
        every: "30m",
        model: "claude-max/claude-sonnet-4-5",
        target: "last",
        activeHours: {
          start: "08:00",
          end: "22:00",
          timezone: "America/Los_Angeles"
        }
      },

      // Sandbox for non-main sessions
      sandbox: {
        mode: "non-main",
        scope: "agent",
        docker: {
          image: "openclaw-sandbox:bookworm-slim",
          network: "none",
          readOnlyRoot: true
        }
      }
    }
  },

  // Messaging channels
  channels: {
    whatsapp: {
      dmPolicy: "pairing",
      // Your phone number in E.164 format
      allowFrom: ["+19174424069"],
      // Disable group chats initially
      groupPolicy: "disabled",
      sendReadReceipts: true,
      textChunkLimit: 4000
    },

    telegram: {
      // Bot token from @BotFather — set TELEGRAM_BOT_TOKEN in ~/.openclaw/.env.secrets
      botToken: "${TELEGRAM_BOT_TOKEN}",
      dmPolicy: "allowlist",
      allowFrom: [8092664267],
      groupPolicy: "disabled",
      streamMode: "partial"
    }
  }
}
